{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":timezone(Europe/Paris)",
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":enablePreCommit",
    ":automergeBranch",
    "github>spike442/homelab//.renovate/autoMerge.json5",
    "github>spike442/homelab//.renovate/labels.json5",
    "github>spike442/homelab//.renovate/semanticCommits.json5",
    "github>spike442/homelab//.renovate/packageGroups.json5"
  ],
  "ignorePaths": [
        "**/resources/**",
  ],
  "flux": {
    "fileMatch": [
      "(^|/)kubernetes/.+\\.ya?ml$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "(^|/)kubernetes/.+\\.ya?ml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "(^|/)kubernetes/.+\\.ya?ml$"
    ]
  },
  "docker-compose": {
    "fileMatch": [
      "(^|/)ansible/.+compose\\.ya?ml$"
    ]
  },
  "ansible-galaxy": {
    "fileMatch": [
      "(^|/)ansible/requirements\\.ya?ml$"
    ]
  }
}
